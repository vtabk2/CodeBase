<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:gravity="bottom|center_horizontal"
    android:orientation="vertical"
    android:background="#5C6BC0"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvMascotMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_32dp"
        android:layout_marginBottom="@dimen/_8dp"
        android:background="#26000000"
        android:gravity="center"
        android:paddingHorizontal="@dimen/_14dp"
        android:paddingVertical="@dimen/_8dp"
        android:textColor="@color/white"
        android:textSize="@dimen/_13dp"
        app:layout_constraintBottom_toTopOf="@id/progressSplash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Checking privacy settings. One moment..." />

    <ProgressBar
        android:id="@+id/progressSplash"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="@dimen/_8dp"
        android:layout_marginHorizontal="@dimen/_32dp"
        android:layout_marginTop="@dimen/_24dp"
        android:layout_marginBottom="@dimen/_20dp"
        android:max="15000"
        android:progress="0"
        android:progressBackgroundTint="#33FFFFFF"
        android:progressTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>